# Optional: Sanity CMS (public read). Create project at https://www.sanity.io/
# After `npm run studio`, copy Project ID here and publish a "Portfolio" document.
VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2024-01-01

# Optional: AI chat — full URL to a server that implements POST /api/chat
# Deploy this repo to Vercel (api/chat.js) and set OPENAI_API_KEY in Vercel env.
# Example: https://your-app.vercel.app/api/chat
VITE_CHAT_API_URL=
